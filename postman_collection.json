{
  "info": {
    "name": "FreightSystem API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Basic API collection for Freight Forwarding system"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "https://localhost:5001/api/v1.0/auth/login",
          "protocol": "https",
          "host": ["localhost"],
          "port": "5001",
          "path": ["api", "v1.0", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"admin\",\"password\":\"Admin123!\"}"
        }
      }
    },
    {
      "name": "Get Customers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "https://localhost:5001/api/v1.0/customers",
          "protocol": "https",
          "host": ["localhost"],
          "port": "5001",
          "path": ["api", "v1.0", "customers"]
        }
      }
    },
    {
      "name": "Create Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Postman Customer\",\"email\":\"postman@customer.test\",\"phone\":\"01000000000\",\"address\":\"Cairo\",\"creditLimit\":10000,\"balance\":0}"
        },
        "url": {
          "raw": "https://localhost:5001/api/v1.0/customers",
          "protocol": "https",
          "host": ["localhost"],
          "port": "5001",
          "path": ["api", "v1.0", "customers"]
        }
      }
    }
  ]
}
